# ═══════════════════════════════════════════════════════════════════════
# RAILWAY ENVIRONMENT VARIABLES
# Set these in Railway Dashboard for each service
# ═══════════════════════════════════════════════════════════════════════

# ─── Main Backend Service ───────────────────────────────────────────

# Database (Railway PostgreSQL addon - auto-provided)
DATABASE_URL=postgresql+asyncpg://user:password@postgres.railway.internal:5432/railway

# Redis (Railway Redis addon - auto-provided)
REDIS_URL=redis://default:password@redis.railway.internal:6379

# JWT Authentication
JWT_SECRET=your-64-char-secret-here
JWT_ALGORITHM=HS256

# Email (SMTP)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=NovaTech

# Domain (main backend Railway public URL)
DOMAIN=main-backend.up.railway.app

# CORS Origins (comma-separated frontend URLs)
CORS_ORIGINS=https://your-user-frontend.vercel.app,https://your-admin-frontend.vercel.app

# Trusted Hosts
TRUSTED_HOSTS=*.up.railway.app,localhost

# Admin Backend URL (internal Railway communication)
ADMIN_BACKEND_URL=http://admin-backend.railway.internal:8002

# Chatbot - GROQ (LLM)
groq_api_key_3=gsk_your_groq_api_key_here

# Chatbot - Cohere (Embeddings)
COHERE_API_KEY=your_cohere_api_key_here
COHERE_EMBED_MODEL=embed-v4.0

# Chatbot - Supabase (PDF Storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key

# MCP Server Path (in Docker container)
MCP_SERVER_PATH=/app/src/chatbot/MCP_Server.py

# Use FAISS (optional, set to true to use FAISS instead of cosine retriever)
USE_FAISS=false

# ─── Admin Backend Service ──────────────────────────────────────────

# Redis (same addon as main backend)
REDIS_URL=redis://default:password@redis.railway.internal:6379

# CORS Origins (admin frontend URL)
CORS_ORIGINS=https://your-admin-frontend.vercel.app

# Trusted Hosts
TRUSTED_HOSTS=*.up.railway.app,localhost

# ─── Celery Worker Service ──────────────────────────────────────────

# Database (same PostgreSQL addon)
DATABASE_URL=postgresql+asyncpg://user:password@postgres.railway.internal:5432/railway

# Redis (same addon - used as broker and result backend)
REDIS_URL=redis://default:password@redis.railway.internal:6379


# ═══════════════════════════════════════════════════════════════════════
# VERCEL ENVIRONMENT VARIABLES
# Set these in Vercel Dashboard for each frontend
# ═══════════════════════════════════════════════════════════════════════

# ─── User Frontend (Vercel) ─────────────────────────────────────────

# Main Backend URL (Railway public URL)
NEXT_PUBLIC_API_URL=https://main-backend.up.railway.app

# WebSocket URL (wss:// for secure WebSocket from Vercel)
NEXT_PUBLIC_WS_URL=wss://main-backend.up.railway.app

# ─── Admin Frontend (Vercel) ────────────────────────────────────────

# Admin Backend URL (Railway public URL)
NEXT_PUBLIC_ADMIN_API_URL=https://admin-backend.up.railway.app

# Main Backend URL (Railway public URL)
NEXT_PUBLIC_MAIN_API_URL=https://main-backend.up.railway.app

# Admin Password
NEXT_PUBLIC_ADMIN_PASSWORD=your-admin-password
